      "targets": [
        {
          "query": "from(bucket: \"conveyor_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"conveyor_belt\" and r._field == \"fault_type\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: r._value}))",
          "refId": "A"
