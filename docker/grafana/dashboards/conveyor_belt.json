      "title": "RUL Countdown",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 23 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "decimals": 1,
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 998,
                "to": 1000,
                "result": { "text": "✅ Stable", "color": "green" }
