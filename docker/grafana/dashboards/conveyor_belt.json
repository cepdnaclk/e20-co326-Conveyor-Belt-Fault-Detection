          "mappings": [
            { "type": "value", "options": { "normal": { "text": "✅ Normal", "color": "green" } } },
            { "type": "value", "options": { "belt_slip": { "text": "⚠ Belt Slip", "color": "yellow" } } },
            { "type": "value", "options": { "roller_fault": { "text": "🔶 Roller Fault", "color": "orange" } } },
