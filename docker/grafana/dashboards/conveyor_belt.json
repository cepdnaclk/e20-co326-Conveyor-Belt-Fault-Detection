        "justifyMode": "center"
      },
      "alert": {
        "name": "RUL Critical — Belt Failure Imminent",
        "message": "Remaining Useful Life has dropped below 5 minutes. Immediate maintenance required.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": { "type": "lt", "params": [5] },
            "operator": { "type": "and" }
          }
        ],
        "frequency": "10s",
        "for": "30s",
        "noDataState": "no_data",
        "executionErrorState": "alerting",
        "handler": 1
      },
      "targets": [
        {
          "query": "from(bucket: \"conveyor_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"rul_estimate\" and r._field == \"rul_minutes\")\n  |> last()",
